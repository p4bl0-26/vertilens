{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "ESNext",
    "moduleResolution":  "Bundler",
    "strict":            true,
    "declaration":       true,
    "skipLibCheck":      true,
    "esModuleInterop":   true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
